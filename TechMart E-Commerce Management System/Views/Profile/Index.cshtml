@model TechMart_E_Commerce_Management_System.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center mt-5">

    ```
    <div class="col-lg-8">

        <div class="card shadow">

            <div class="card-body p-4">

                <div class="text-center mb-4">

                    @if (!string.IsNullOrWhiteSpace(Model.ProfileImage))
                    {
                        <img src="@Model.ProfileImage"
                             alt="Profile Image"
                             class="profile-image mb-3" />
                    }
                    else
                    {
                        <img src="https://via.placeholder.com/150"
                             alt="Profile Image"
                             class="profile-image mb-3" />
                    }

                    <h3 class="fw-bold">
                        @Model.Name
                    </h3>

                    <p class="text-muted">
                        @Model.Role
                    </p>

                </div>

                <hr />

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <strong>User ID</strong>

                        <div class="text-muted">
                            @Model.UserId
                        </div>

                    </div>

                    <div class="col-md-6 mb-3">

                        <strong>Email</strong>

                        <div class="text-muted">
                            @Model.Email
                        </div>

                    </div>

                    <div class="col-md-6 mb-3">

                        <strong>Role</strong>

                        <div class="text-muted">
                            @Model.Role
                        </div>

                    </div>

                    <div class="col-md-6 mb-3">

                        <strong>Member Since</strong>

                        <div class="text-muted">
                            @Model.CreatedAt.ToString("dd MMM yyyy")
                        </div>

                    </div>

                </div>

                <div class="mt-3">

                    <a asp-action="Edit"
                       class="btn btn-primary">
                        Edit Profile
                    </a>

                    <a asp-controller="Auth"
                       asp-action="ChangePassword"
                       class="btn btn-warning">
                        Change Password
                    </a>

                </div>

            </div>

        </div>

    </div>
    ```

</div>
